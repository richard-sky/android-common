<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:text="提示"
        android:textColor="@color/text"
        android:textSize="@dimen/text_view_textSize"
        android:textStyle="bold"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/dialog_common_tip_fl_content_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/dialog_content_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginStart="8dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="10dp"
        android:gravity="center"
        android:lineSpacingExtra="5dp"
        android:maxHeight="300dp"
        android:scrollbars="vertical"
        android:textColor="@color/text"
        android:textSize="@dimen/text_view_textSize"
        android:visibility="gone" />


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:orientation="vertical">

        <View
            android:id="@+id/dialog_content"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/line_size"
            android:background="@color/light_line" />

        <LinearLayout
            android:id="@+id/content_btn"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/normal_button_height"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dialog_left_tv"
                android:gravity="center"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:autoSizeMaxTextSize="@dimen/button_text_size"
                android:autoSizeMinTextSize="@dimen/textSize_13"
                android:autoSizeTextType="uniform"
                android:maxLines="1"
                android:text="取消"
                android:textColor="@color/text"
                android:visibility="gone" />

            <View
                android:id="@+id/line_one"
                android:layout_width="@dimen/line_size"
                android:layout_height="match_parent"
                android:background="@color/light_line"
                android:visibility="gone" />

            <TextView
                android:id="@+id/dialog_center_tv"
                android:gravity="center"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:autoSizeMaxTextSize="@dimen/button_text_size"
                android:autoSizeMinTextSize="@dimen/textSize_13"
                android:autoSizeTextType="uniform"
                android:maxLines="1"
                android:text="中间按钮"
                android:textColor="@color/text"
                android:visibility="gone" />

            <View
                android:id="@+id/line_two"
                android:layout_width="@dimen/line_size"
                android:layout_height="match_parent"
                android:background="@color/light_line"
                android:visibility="gone" />

            <TextView
                android:id="@+id/dialog_right_tv"
                android:gravity="center"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:autoSizeMaxTextSize="@dimen/button_text_size"
                android:autoSizeMinTextSize="@dimen/textSize_13"
                android:autoSizeTextType="uniform"
                android:maxLines="1"
                android:text="确定"
                android:textColor="@color/text"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>


</LinearLayout>