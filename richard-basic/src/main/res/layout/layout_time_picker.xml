<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <com.richard.library.basic.widget.NavigationBar
            android:id="@+id/navigation_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/navigation_bar_height"
            app:nav_left_text="取消"
            app:nav_right_text="确定"
            app:nav_title_text="时间选择"
            app:nav_topLeftRadius="@dimen/radius_value"
            app:nav_topRightRadius="@dimen/radius_value" />

        <TimePicker
            android:id="@+id/time_picker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:theme="@style/time_picker_style"
            android:timePickerMode="spinner" />

    </LinearLayout>

</layout>