<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:id="@+id/content_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@mipmap/img_update"
            android:padding="20dp">

            <com.makeramen.roundedimageview.RoundedImageView
                android:id="@+id/iv_app_icon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginRight="12dp"
                android:visibility="gone"
                app:riv_corner_radius="15dp" />

            <LinearLayout
                android:id="@+id/content_version_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toRightOf="@id/iv_app_icon"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="升级软件版本"
                    android:textColor="@color/white"
                    android:textSize="@dimen/textSize_18"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_app_upgrade_versionName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="V1.0.0"
                    android:textColor="@color/white"
                    android:textSize="@dimen/textSize_12"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/content_version_name"
                android:layout_marginTop="9dp"
                android:layout_toRightOf="@id/iv_app_icon"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="文件大小 : "
                    android:textColor="@color/white"
                    android:textSize="@dimen/textSize_12" />

                <TextView
                    android:id="@+id/tv_file_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:text="12.6M"
                    android:textColor="@color/white"
                    android:textSize="@dimen/textSize_12" />

            </LinearLayout>

        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/content_update_remark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:text="更新内容"
                    android:textColor="@color/text"
                    android:textSize="@dimen/textSize_14"
                    android:textStyle="bold" />

                <ScrollView
                    android:id="@+id/osv_app_upgrade_remark"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/tv_app_upgrade_remark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="7dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="1.新增余额生息功能\n2.新增查看收款返佣和商品收益列表\n3.优化调整部分UI"
                        android:textColor="@color/text"
                        android:textSize="@dimen/textSize_12" />

                </ScrollView>

            </LinearLayout>


            <LinearLayout
                android:id="@+id/ll_app_upgrade_progress_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginRight="20dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_progress_tip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="正在下载文件..."
                    android:textColor="@color/text"
                    android:textSize="@dimen/textSize_14" />

                <ProgressBar
                    android:id="@+id/progressbar"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progressDrawable="@drawable/layer_list_progress_drawable" />

            </LinearLayout>

            <View
                android:id="@+id/line_view"
                style="@style/line_horizontal_gray_style"
                android:layout_marginTop="15dp" />

            <LinearLayout
                android:id="@+id/ll_app_upgrade_bv_content"
                android:layout_width="match_parent"
                android:layout_height="@dimen/middle_button_height"
                android:layout_margin="10dp"
                android:gravity="end"
                android:orientation="horizontal">

                <com.richard.library.basic.widget.ButtonView
                    android:id="@+id/bv_cancel"
                    style="@style/button_line_style.wrap"
                    android:layout_height="match_parent"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:minWidth="0dp"
                    android:textSize="@dimen/textSize_14"
                    android:text="暂不升级"/>

                <View
                    android:id="@+id/view_app_upgrade_offset"
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:id="@+id/content_upgrade"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent">

                    <com.richard.library.basic.widget.ButtonView
                        android:id="@+id/bv_upgrade_browser"
                        style="@style/button_style.wrap"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:layout_height="match_parent"
                        android:text="通过浏览器升级"
                        android:textSize="@dimen/textSize_14" />

                    <com.richard.library.basic.widget.ButtonView
                        android:id="@+id/bv_upgrade"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:minWidth="0dp"
                        android:layout_marginStart="10dp"
                        style="@style/button_style.wrap"
                        android:layout_height="match_parent"
                        android:text="立即升级"
                        android:textSize="@dimen/textSize_14" />

                </LinearLayout>

                <com.richard.library.basic.widget.ButtonView
                    android:id="@+id/bv_install"
                    style="@style/button_style.wrap"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:visibility="gone"
                    android:text="立即安装"
                    android:textSize="@dimen/textSize_14" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</layout>